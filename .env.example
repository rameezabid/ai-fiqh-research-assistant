# Required credentials
TELEGRAM_BOT_TOKEN=replace_with_your_telegram_bot_token
OPENAI_API_KEY=replace_with_your_openai_api_key
OPENAI_MODEL=gpt-5.4-mini

# Access control
# Keep PUBLIC_BOT=false to restrict the bot to this one Telegram user ID.
# Use @userinfobot in Telegram to find your numeric Telegram user ID.
PUBLIC_BOT=false
ALLOWED_TELEGRAM_USER_ID=123456789

# Turath category IDs
HANBALI_CATEGORY_ID=17
HANAFI_CATEGORY_ID=14
MALIKI_CATEGORY_ID=15
SHAFI_CATEGORY_ID=16
# Separate Usul al-Fiqh category (not included in /all).
USOOL_CATEGORY_ID=11

# Optional preferred Turath book IDs. Separate multiple IDs with commas.
# Normal commands search preferred books first AND then books outside the
# preferred list in the full configured category.
# Preferred-only commands (/hanbalipref, /usoolpref, etc.) search only these IDs.
HANBALI_PREFERRED_BOOKS=1262,1679,19228,21693,30004,622,6910,12052,147311,20878,19233,21731,1153,151,21743,7360,20589,14386,16772,1241,18353,96876,30066,6115,7725,17817,12216
HANAFI_PREFERRED_BOOKS=
MALIKI_PREFERRED_BOOKS=
SHAFI_PREFERRED_BOOKS=
USOOL_PREFERRED_BOOKS=

# Retrieval controls
# Maximum number of Arabic queries created from one user question.
TURATH_SEARCH_QUERY_COUNT=4
# Max search hits requested from Turath for each query.
TURATH_RESULTS_PER_QUERY=5
# Max unique results retained for each selected school.
TURATH_MAX_RESULTS_PER_SCHOOL=10

# Context expansion controls.
# 0 for TURATH_CONTEXT_TOP_N expands all retained results.
# 0 for TURATH_CONTEXT_RADIUS disables nearby-page expansion.
TURATH_CONTEXT_TOP_N=5
TURATH_CONTEXT_RADIUS=3

# Limits sent to the OpenAI answer prompt.
TURATH_RESULT_TEXT_CHARS=2600
TURATH_CONTEXT_PAGE_CHARS=3500

# Turath request reliability and pacing.
TURATH_REQUEST_TIMEOUT=25
TURATH_MAX_RETRIES=3
TURATH_BACKOFF_SECONDS=2
TURATH_DELAY_BETWEEN_CALLS_MS=350

# Optional Brave Search for /fatwa, /islamqa, and /islamweb.
# Leave BRAVE_SEARCH_API_KEY blank to keep these website commands disabled.
BRAVE_SEARCH_API_KEY=
BRAVE_SEARCH_RESULTS_PER_QUERY=5
FATWA_MAX_PAGES_PER_SITE=4
FATWA_REQUEST_TIMEOUT=25
FATWA_MAX_RETRIES=3
FATWA_DELAY_BETWEEN_CALLS_MS=500
